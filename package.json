{
  "name": "article-distributor",
  "version": "1.0.0",
  "description": "多平台文章分发CLI工具 - 一键发布到掘金、CSDN、博客园等平台",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ad": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "article",
    "publish",
    "cli",
    "multi-platform",
    "juejin",
    "csdn",
    "cnblogs"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.2.15",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "conf": "^12.0.0",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.12",
    "puppeteer": "^22.0.0",
    "marked": "^12.0.0",
    "gray-matter": "^4.0.3",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.3.1",
    "cli-table3": "^0.6.3",
    "update-notifier": "^7.0.0",
    "figlet": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/inquirer": "^9.0.7",
    "@types/crypto-js": "^4.2.2",
    "@types/figlet": "^1.5.8",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.2.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0"
  }
}
